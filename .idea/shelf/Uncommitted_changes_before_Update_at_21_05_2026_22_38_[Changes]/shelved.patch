<+>{% load static %}\r\n<!doctype html>\r\n<html lang=\"ru\">\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\"\r\n          content=\"width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0\">\r\n    <meta http-equiv=\"X-UA-Compatible\" content=\"ie=edge\">\r\n    <title>{% block title %}{% endblock %}</title>\r\n    <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css\">\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Alumni+Sans+SC:wght@100..900&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"{% static 'main/css/main.css' %}\">\r\n</head>\r\n<body class=\"{% block body_class %}{% endblock %}\">\r\n  <div class=\"hero\">\r\n    <!-- затемнение и содержимое поверх фона -->\r\n    <div class=\"container-hero\">\r\n      {% block content %}{% endblock %}\r\n    </div>\r\n\r\n    <div class=\"photo-credit\">\r\n    Фото: Сергей Токарев | @tokarevs\r\n    </div>\r\n\r\n    <!-- Правая панель (везде одинаковая) -->\r\n    <aside class=\"side-panel\">\r\n    {% if user.is_authenticated %}\r\n        <a href=\"{% url 'profile' %}\" class=\"avatar-link\">\r\n            <div class=\"avatar\">\r\n                {% if user.profile.avatar %}\r\n                    <img src=\"{{ user.profile.avatar.url }}\" style=\"width:100%; border-radius:50%\">\r\n                {% else %}\r\n                    {{ user.username|slice:\":2\"|upper }}\r\n                {% endif %}\r\n            </div>\r\n        </a>\r\n\r\n        <div style=\"color: white; text-align: center; margin-top: 10px; font-weight: bold;\">\r\n            {{ user.username }}\r\n        </div>\r\n        \r\n        <nav class=\"nav\">\r\n            <a href=\"{% url 'profile' %}\">Мой профиль</a>\r\n            <a href=\"{% url 'logout' %}\">Выйти</a>\r\n\r\n            <a href=\"{% url 'favorites' %}\">Избранное</a>\r\n            <a href=\"{% url 'create_tour' %}\">Собери тур</a>\r\n            <a href=\"{% url 'home' %}\">Главная</a>\r\n            <a href=\"{% url 'guide' %}\">Путеводитель</a>\r\n            <a href=\"{% url 'events_home' %}\">События</a>\r\n            <a href=\"{% url 'about' %}\">О нас</a>\r\n\r\n        </nav>\r\n    {% else %}\r\n        <div class=\"auth-block\">\r\n            {% block auth_content %}\r\n                <h2 class=\"auth-title\">Ваш Туризм</h2>\r\n                <hr style=\"width: 80%; border-color: rgba(255,255,255,0.1); margin: 0 auto 40px auto;\">\r\n                <nav class=\"nav\">\r\n                    <a href=\"{% url 'login' %}\" class=\"auth-link\">Войти</a>\r\n                    <a href=\"{% url 'register' %}\" class=\"auth-link\">Зарегистрироваться</a>\r\n\r\n                    <hr style=\"width: 80%; border-color: rgba(255,255,255,0.1); margin: 0 auto 80px auto;\">\r\n\r\n                    <a href=\"{% url 'home' %}\">Главная</a>\r\n                    <a href=\"{% url 'events_home' %}\">События</a>\r\n                    <a href=\"{% url 'about' %}\">О нас</a>\r\n                </nav>\r\n            {% endblock %}\r\n        </div>\r\n    {% endif %}\r\n\r\n      <button class=\"side-toggle\" aria-expanded=\"true\" title=\"Развернуть/Свернуть панель\">\r\n        <svg width=\"20\" height=\"12\" viewBox=\"0 0 20 12\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\r\n          <rect width=\"20\" height=\"2\" rx=\"1\" fill=\"currentColor\"/>\r\n          <rect y=\"5\" width=\"20\" height=\"2\" rx=\"1\" fill=\"currentColor\"/>\r\n          <rect y=\"10\" width=\"20\" height=\"2\" rx=\"1\" fill=\"currentColor\"/>\r\n        </svg>\r\n      </button>\r\n    </aside>\r\n  </div>\r\n\r\n  <script src=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js\"></script>\r\n  <script src=\"{% static 'main/js/main.js' %}\"></script>\r\n</body>\r\n</html>
